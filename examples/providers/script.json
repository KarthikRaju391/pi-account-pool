{
  "type": "my-provider",
  "authKey": "my-provider-auth-key-in-auth-json",
  "accountDirTemplate": "~/.pi/accounts/my-provider-{{id}}",
  "labels": { "primary": "short", "secondary": "weekly" },
  "accounts": [
    { "id": "primary", "enabled": true },
    { "id": "secondary", "enabled": true }
  ],
  "usage": {
    "type": "script",
    "command": "my-usage-checker --auth-dir {{account.dir}} --account {{id}}",
    "paths": {
      "allowed": "allowed",
      "primaryUsedPercent": "primary.used_percent",
      "primaryResetAfterSeconds": "primary.reset_after_seconds",
      "secondaryUsedPercent": "weekly.used_percent",
      "secondaryResetAfterSeconds": "weekly.reset_after_seconds",
      "limitReached": "limit_reached"
    }
  }
}
